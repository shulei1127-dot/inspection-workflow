# App
DATABASE_URL=postgresql+psycopg://inspection:inspection@localhost:5432/inspection_workflow
SERVER_PORT=8100

# PTS API
PTS_GRAPHQL_URL=http://api.in.chaitin.net/pts/query
PTS_API_TOKEN=pt_xxx
PTS_RATE_LIMIT=4.0

# DingTalk AITable - 日常增值服务进展 (sync + monitor)
DT_AITABLE_BASE_ID=
DT_AITABLE_TABLE_ID=
DT_POLL_INTERVAL=300
DT_POLL_ENABLED=true

# DingTalk AITable - 客户巡检派单 (monitor only)
DT_DISPATCH_BASE_ID=
DT_DISPATCH_TABLE_ID=

# Trigger controls
AUTO_DISPATCH_ENABLED=false
AUTO_EMAIL_ENABLED=false

# External Services
YUNJI_SESSION_COOKIE=  # yunji_session_id=xxx; go-server-token=yyy (from browser DevTools)
INSPECTION_EMAIL_SMTP_HOST=smtpdm.aliyun.com
INSPECTION_EMAIL_SMTP_PORT=465
INSPECTION_EMAIL_SENDER=inspection@product-support.chaitin.com
INSPECTION_EMAIL_PASSWORD=xxx
AI_API_KEY=xxx

# Scheduler
SYNC_CRON=0 */2 * * *
SCHEDULER_ENABLED=true

# Logging
LOG_LEVEL=INFO
